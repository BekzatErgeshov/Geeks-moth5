# Скопируйте этот файл в .env и подставьте свои значения.
# EMAIL_HOST_PASSWORD — это пароль приложения из Google-аккаунта
# (Google Account -> Security -> 2-Step Verification -> App passwords),
# а НЕ обычный пароль от почты.
#
# Реальные значения храните только в .env — он в .gitignore.
# В этом файле должны оставаться заглушки.

EMAIL_HOST_USER=your.address@gmail.com
EMAIL_HOST_PASSWORD=xxxxxxxxxxxxxxxx
DEFAULT_FROM_EMAIL=your.address@gmail.com
